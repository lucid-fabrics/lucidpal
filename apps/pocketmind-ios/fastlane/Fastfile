fastlane_version "2.225.0"

default_platform(:ios)

SCHEME      = "PocketMind"
PROJECT     = "PocketMind.xcodeproj"
BUNDLE_ID   = "app.pocketmind"
TEAM_ID     = "25YLHGUW42"
# Override via: export DEVICE_UDID=<your-udid>  (xcrun xctrace list devices)
DEVICE_UDID = ENV["DEVICE_UDID"] || "00008150-000C08842604401C"

platform :ios do

  # ─────────────────────────────────────────────
  # Regenerate Xcode project from project.yml
  # ─────────────────────────────────────────────
  desc "Regenerate .xcodeproj from project.yml using xcodegen"
  lane :generate do
    # __dir__ resolves to the fastlane/ directory regardless of cwd
    project_root = File.expand_path("..", __dir__)
    sh("cd #{project_root} && xcodegen generate")
  end

  # ─────────────────────────────────────────────
  # Prepare device: enable Developer Mode + verify trust
  # iOS requires one manual tap on the device to confirm Developer Mode.
  # After that first tap, this lane is fully silent on repeat runs.
  # ─────────────────────────────────────────────
  desc "Enable Developer Mode on device and verify pairing"
  lane :prepare do
    UI.message("Checking device pairing...")

    # Verify device is trusted (user must have tapped 'Trust' on iPhone once)
    paired = sh("idevicepair pair --udid #{DEVICE_UDID} 2>&1", error_callback: ->(r) {}).strip
    if paired.include?("SUCCESS") || paired.include?("already paired")
      UI.success("Device is paired")
    else
      UI.important("Unlock your iPhone and tap 'Trust This Computer', then press Enter...")
      STDIN.gets
      sh("idevicepair pair --udid #{DEVICE_UDID}")
    end

    UI.message("Enabling Developer Mode (you may need to tap 'Turn On' on the iPhone)...")
    dev_mode_result = sh(
      "xcrun devicectl manage developerMode enable --device #{DEVICE_UDID} 2>&1",
      error_callback: ->(r) {}
    ).strip

    if dev_mode_result.include?("already enabled") || dev_mode_result.include?("success")
      UI.success("Developer Mode already enabled")
    else
      UI.important("Tap 'Turn On' on your iPhone if prompted, then press Enter...")
      STDIN.gets
      # Device restarts after enabling — wait for it to come back
      UI.message("Waiting for device to restart...")
      sleep(15)
    end

    UI.success("Device ready for development")
  end

  # ─────────────────────────────────────────────
  # Build debug IPA and install on connected device
  # fastlane ios device
  # ─────────────────────────────────────────────
  desc "Prepare device, build debug build, and install on connected iPhone"
  lane :device do
    prepare
    generate

    build_app(
      project: PROJECT,
      scheme: SCHEME,
      configuration: "Debug",
      export_method: "development",
      destination: "id=#{DEVICE_UDID}",
      output_directory: "./build",
      output_name: "PocketMind-debug.ipa",
      clean: true,
      xcargs: "DEVELOPMENT_TEAM=#{TEAM_ID} -allowProvisioningUpdates"
    )

    install_on_device(
      udid: DEVICE_UDID,
      ipa: "./build/PocketMind-debug.ipa"
    )

    UI.success("PocketMind installed on Wass iPhone")
  end

  # ─────────────────────────────────────────────
  # Build release IPA and upload to TestFlight
  # fastlane ios beta
  # ─────────────────────────────────────────────
  desc "Build release and upload to TestFlight"
  lane :beta do
    generate

    increment_build_number(
      build_number: latest_testflight_build_number + 1,
      xcodeproj: PROJECT
    )

    build_app(
      project: PROJECT,
      scheme: SCHEME,
      configuration: "Release",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "PocketMind.ipa",
      clean: true,
      xcargs: "DEVELOPMENT_TEAM=#{TEAM_ID} -allowProvisioningUpdates"
    )

    upload_to_testflight(
      skip_waiting_for_build_processing: true
    )

    UI.success("PocketMind uploaded to TestFlight")
  end

  # ─────────────────────────────────────────────
  # Build release IPA and submit to App Store
  # fastlane ios release
  # ─────────────────────────────────────────────
  desc "Build release and submit to App Store"
  lane :release do
    generate

    increment_build_number(
      build_number: latest_testflight_build_number + 1,
      xcodeproj: PROJECT
    )

    build_app(
      project: PROJECT,
      scheme: SCHEME,
      configuration: "Release",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "PocketMind.ipa",
      clean: true,
      xcargs: "DEVELOPMENT_TEAM=#{TEAM_ID} -allowProvisioningUpdates"
    )

    deliver(
      force: true,
      submit_for_review: false,
      automatic_release: false,
      precheck_include_in_app_purchases: false
    )

    UI.success("PocketMind submitted to App Store Connect")
    UI.message("Go to App Store Connect to submit for review when ready")
  end

end
